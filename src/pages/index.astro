---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Hero from "../components/Hero.astro";
import ServiceCard from "../components/ServiceCard.astro";
import OfferSection from "../components/OfferSection.astro";
import ProcessSection from "../components/ProcessSection.astro";
import ContactSection from "../components/ContactSection.astro";
import Footer from "../components/Footer.astro";

const services = [
  {
    title: "MVPs y plataformas para validar ideas",
    description:
      "Construimos la primera versión funcional de tu producto digital para que puedas probarlo con usuarios, venderlo o presentarlo sin quedarte meses en planeación.",
    icon: "M4 7.5A2.5 2.5 0 0 1 6.5 5h11A2.5 2.5 0 0 1 20 7.5v9A2.5 2.5 0 0 1 17.5 19h-11A2.5 2.5 0 0 1 4 16.5v-9ZM8 9h8M8 12h8M8 15h5",
    accent: "blue"
  },
  {
    title: "Landing pages que convierten visitas en clientes",
    description:
      "Diseñamos páginas claras, rápidas y profesionales para presentar tu oferta, captar leads y darle confianza a quienes llegan por campañas, redes o referidos.",
    icon: "M4 6.5A2.5 2.5 0 0 1 6.5 4h11A2.5 2.5 0 0 1 20 6.5v11a2.5 2.5 0 0 1-2.5 2.5h-11A2.5 2.5 0 0 1 4 17.5v-11ZM4 9h16M8 14h3m2 0h3",
    accent: "cyan"
  },
  {
    title: "Automatización de tareas repetitivas",
    description:
      "Conectamos formularios, correos, bases de datos, CRM, hojas de cálculo y herramientas internas para reducir trabajo manual y errores operativos.",
    icon: "M7 7h10M7 12h10M7 17h6M17 17l3-3-3-3",
    accent: "purple"
  },
  {
    title: "Sistemas internos para operar mejor",
    description:
      "Creamos portales, paneles administrativos y flujos a medida para centralizar información, ordenar procesos y darle más control al equipo.",
    icon: "M5 19V9m7 10V5m7 14v-7M3 19h18",
    accent: "blue"
  },
  {
    title: "Datos e IA para tomar mejores decisiones",
    description:
      "Convertimos datos dispersos en reportes, tableros y análisis útiles para entender qué está pasando, detectar oportunidades y priorizar acciones.",
    icon: "M12 3l1.8 4.7L18.5 9.5l-4.7 1.8L12 16l-1.8-4.7L5.5 9.5l4.7-1.8L12 3ZM18 15l.9 2.1L21 18l-2.1.9L18 21l-.9-2.1L15 18l2.1-.9L18 15ZM6 14l.6 1.4L8 16l-1.4.6L6 18l-.6-1.4L4 16l1.4-.6L6 14Z",
    accent: "cyan"
  },
  {
    title: "Integraciones y despliegue listo para operar",
    description:
      "Publicamos tu solución, conectamos las herramientas necesarias y dejamos una base técnica estable para que el proyecto pueda crecer sin depender de improvisaciones.",
    icon: "M8.5 18a3.5 3.5 0 1 1 .55-6.96A5 5 0 0 1 18.77 8.7 3.8 3.8 0 1 1 18 18H8.5Z",
    accent: "purple"
  }
];

const projects = [
  {
    name: "Atenea Seguros",
    type: "Plataforma SaaS / Insurtech",
    description:
      "Plataforma multi-tenant para asesores de seguros, enfocada en gestión de clientes, portafolio de pólizas, campañas de comunicación, carga de datos, dashboards y automatizaciones para operación comercial.",
    tags: ["SaaS", "Seguros", "Automatización", "Dashboards", "Multi-tenant"],
    label: "Cliente",
    accent: "from-sky-500/18 via-blue-500/12 to-transparent"
  },
  {
    name: "Soundscape Climate Intelligence",
    type: "IA aplicada / Ecoacústica",
    description:
      "Sistema de análisis de paisajes sonoros para estudiar la relación entre actividad biológica, actividad humana y variables climáticas. El proyecto clasificó sonidos en biophony, geophony y anthropophony usando modelos de deep learning y embeddings de YAMNet, alcanzando alto desempeño en clasificación acústica.",
    tags: ["Machine Learning", "Audio AI", "YAMNet", "Climate Data", "Ecoacoustics"],
    label: "Investigación aplicada",
    accent: "from-cyan-500/18 via-teal-500/12 to-transparent"
  },
  {
    name: "Localised Augmentation for Medical Image Datasets",
    type: "IA médica / Computer Vision",
    description:
      "Proyecto de investigación en visión por computador para mejorar la segmentación de lesiones en mamografías mediante deformación elástica localizada en regiones de interés. La estrategia permitió generar aumentos más realistas y mejorar el desempeño del modelo frente al baseline.",
    tags: ["Computer Vision", "Medical AI", "U-Net", "Data Augmentation", "Segmentation"],
    label: "Research capability",
    accent: "from-violet-500/18 via-fuchsia-500/12 to-transparent"
  }
];
---

<BaseLayout
  title="MAlabs Group S.A.S. | Software, automatización e IA"
  description="Creamos software a la medida, landing pages, automatizaciones, dashboards y soluciones de inteligencia artificial para empresas y emprendedores."
>
  <Header />
  <main>
    <Hero />

    <section id="servicios" class="pt-6 pb-18 md:pt-8 md:pb-24">
      <div class="section-shell">
        <div class="eyebrow">Servicios</div>
        <div class="grid gap-8 lg:grid-cols-[minmax(0,1.20fr)_minmax(0,0.80fr)] lg:items-center">
          <div class="reveal" data-reveal>
            <h2 class="section-title">
              Soluciones digitales para vender mejor, operar con menos fricción y tomar decisiones con datos.
            </h2>
          </div>
          <p class="section-copy mt-5 lg:mt-0 reveal stagger-1 max-w-2xl lg:justify-self-end" data-reveal>
            Trabajamos desde necesidades concretas de negocio: captar más demanda, operar mejor, centralizar datos, automatizar tareas o construir un producto digital con una base técnica confiable.
          </p>
        </div>

        <div class="mt-12 grid gap-4 md:grid-cols-2 xl:grid-cols-3">
          {services.map((service, index) => (
            <div class={`${index === 1 ? "stagger-1" : ""} ${index === 2 ? "stagger-2" : ""} ${index === 3 ? "stagger-1" : ""} ${index === 4 ? "stagger-2" : ""} ${index === 5 ? "stagger-3" : ""} reveal`} data-reveal>
              <ServiceCard {...service} />
            </div>
          ))}
        </div>
      </div>
    </section>

    <section id="proyectos" class="pt-6 pb-18 md:pt-8 md:pb-24">
      <div class="section-shell">
        <div class="grid gap-8 lg:grid-cols-[minmax(0,0.85fr)_minmax(0,1fr)] lg:items-end">
          <div class="reveal" data-reveal>
            <div class="eyebrow">Proyectos</div>
            <h2 class="section-title mt-5">Proyectos que reflejan lo que construimos</h2>
          </div>
          <p class="section-copy reveal stagger-1 max-w-2xl lg:justify-self-end" data-reveal>
            Mezclamos trabajo comercial e investigación aplicada para demostrar criterio de producto, ingeniería y capacidad real en datos e inteligencia artificial.
          </p>
        </div>

        <div class="mt-12 space-y-5">
          {projects.map((project, index) => (
            <article class={`section-card card-hover reveal overflow-hidden rounded-[2rem] p-6 md:p-8 ${index === 1 ? "stagger-1" : ""} ${index === 2 ? "stagger-2" : ""}`} data-reveal>
              <div class="grid gap-8 lg:grid-cols-[minmax(0,1.25fr)_minmax(280px,0.75fr)] lg:items-center">
                <div>
                  <div class="flex flex-wrap items-center gap-3">
                    <span class="eyebrow !py-1 !text-[11px]">{project.label}</span>
                    <span class="text-sm font-medium text-slate-500">{project.type}</span>
                  </div>
                  <h3 class="mt-5 text-2xl font-semibold text-slate-950 md:text-3xl">{project.name}</h3>
                  <p class="mt-4 text-base leading-7 text-slate-600">{project.description}</p>
                  <div class="mt-6 flex flex-wrap gap-2">
                    {project.tags.map((tag) => (
                      <span class="tag">{tag}</span>
                    ))}
                  </div>
                </div>

                <div class="gradient-border">
                  <div class="relative overflow-hidden rounded-[1.75rem] border border-slate-200 bg-white p-6">
                    <div class={`absolute inset-0 bg-gradient-to-br ${project.accent}`}></div>
                    <div class="signal-grid absolute inset-0 opacity-40"></div>
                    <div class="relative flex min-h-[220px] flex-col justify-between">
                      <div class="flex items-start justify-between">
                        <span class="rounded-full border border-slate-200 bg-white/85 px-3 py-1 text-xs font-semibold uppercase tracking-[0.18em] text-slate-700">
                          {project.type}
                        </span>
                        <span class="text-xs font-medium uppercase tracking-[0.24em] text-slate-500">
                          MAlabs
                        </span>
                      </div>
                      <div class="space-y-4">
                        <div class="h-px w-full bg-gradient-to-r from-sky-500/40 via-violet-500/40 to-transparent"></div>
                        <div class="grid grid-cols-3 gap-3">
                          <div class="rounded-2xl border border-white/60 bg-white/75 p-4">
                            <div class="h-12 rounded-xl bg-[linear-gradient(180deg,rgba(35,101,189,0.18),rgba(35,101,189,0.02))]"></div>
                          </div>
                          <div class="rounded-2xl border border-white/60 bg-white/75 p-4">
                            <div class="h-12 rounded-xl bg-[linear-gradient(180deg,rgba(19,148,215,0.18),rgba(19,148,215,0.02))]"></div>
                          </div>
                          <div class="rounded-2xl border border-white/60 bg-white/75 p-4">
                            <div class="h-12 rounded-xl bg-[linear-gradient(180deg,rgba(93,50,152,0.18),rgba(93,50,152,0.02))]"></div>
                          </div>
                        </div>
                      </div>
                    </div>
                  </div>
                </div>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <OfferSection />
    <ProcessSection />


    <ContactSection />
  </main>
  <Footer />
</BaseLayout>
