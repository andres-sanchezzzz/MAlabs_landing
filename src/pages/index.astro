---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Hero from "../components/Hero.astro";
import ServiceCard from "../components/ServiceCard.astro";
import OfferSection from "../components/OfferSection.astro";
import ProcessSection from "../components/ProcessSection.astro";
import ContactSection from "../components/ContactSection.astro";
import Footer from "../components/Footer.astro";

const values = [
  {
    title: "Rápido de lanzar",
    description: "Construimos con foco, prioridades claras y una ejecución que evita pasos innecesarios.",
    icon: "M4 12h16M12 4l8 8-8 8"
  },
  {
    title: "Diseñado para escalar",
    description: "Pensamos la base técnica para que el producto pueda crecer sin rehacerse desde cero.",
    icon: "M6 18L18 6M8 6h10v10"
  },
  {
    title: "Orientado a negocio",
    description: "Cada entrega responde a una necesidad concreta de operación, crecimiento o validación.",
    icon: "M4 17l5-5 4 4 7-7M14 9h5v5"
  }
];

const services = [
  {
    title: "Custom software",
    description: "Aplicaciones y plataformas hechas a la medida para resolver procesos críticos con una experiencia clara y una base sólida.",
    icon: "M4 7.5A2.5 2.5 0 0 1 6.5 5h11A2.5 2.5 0 0 1 20 7.5v9A2.5 2.5 0 0 1 17.5 19h-11A2.5 2.5 0 0 1 4 16.5v-9ZM8 9h8M8 12h8M8 15h5"
  },
  {
    title: "Landing pages y websites",
    description: "Sitios rápidos, elegantes y enfocados en posicionar mejor tu propuesta y convertir interés en conversaciones.",
    icon: "M4 6.5A2.5 2.5 0 0 1 6.5 4h11A2.5 2.5 0 0 1 20 6.5v11a2.5 2.5 0 0 1-2.5 2.5h-11A2.5 2.5 0 0 1 4 17.5v-11ZM4 9h16M8 14h3m2 0h3"
  },
  {
    title: "Process automation",
    description: "Automatizamos tareas repetitivas e integramos herramientas para reducir fricción y liberar capacidad operativa.",
    icon: "M7 7h10M7 12h10M7 17h6M17 17l3-3-3-3"
  },
  {
    title: "Data dashboards y analytics",
    description: "Convertimos datos dispersos en tableros accionables para entender mejor el negocio y decidir con más contexto.",
    icon: "M5 19V9m7 10V5m7 14v-7M3 19h18"
  },
  {
    title: "AI y soluciones generativas",
    description: "Aplicamos IA donde aporta valor real: asistentes, flujos inteligentes, clasificación, búsqueda y automatización avanzada.",
    icon: "M12 3l1.8 4.7L18.5 9.5l-4.7 1.8L12 16l-1.8-4.7L5.5 9.5l4.7-1.8L12 3ZM18 15l.9 2.1L21 18l-2.1.9L18 21l-.9-2.1L15 18l2.1-.9L18 15ZM6 14l.6 1.4L8 16l-1.4.6L6 18l-.6-1.4L4 16l1.4-.6L6 14Z"
  },
  {
    title: "Cloud e integrations",
    description: "Conectamos servicios, despliegues e infraestructura moderna para que la solución funcione de forma confiable desde el día uno.",
    icon: "M8.5 18a3.5 3.5 0 1 1 .55-6.96A5 5 0 0 1 18.77 8.7 3.8 3.8 0 1 1 18 18H8.5Z"
  }
];
---

<BaseLayout>
  <Header />
  <main>
    <Hero />

    <section class="pb-18 md:pb-24">
      <div class="section-shell">
        <div class="mx-auto max-w-3xl text-center reveal" data-reveal>
          <div class="eyebrow">Valor</div>
          <h2 class="section-title mt-5">Tecnología clara para mover negocio, no para complicarlo.</h2>
          <p class="section-copy mt-5">
            Diseñamos soluciones digitales con una mezcla de velocidad, criterio técnico y enfoque práctico para que cada entrega tenga un propósito real.
          </p>
        </div>

        <div class="mt-12 grid gap-4 md:grid-cols-3">
          {values.map((value, index) => (
            <article class={`section-card card-hover reveal rounded-[1.75rem] p-6 ${index === 1 ? "stagger-1" : ""} ${index === 2 ? "stagger-2" : ""}`} data-reveal>
              <div class="flex h-12 w-12 items-center justify-center rounded-2xl border border-violet-400/20 bg-violet-400/10 text-violet-200">
                <svg viewBox="0 0 24 24" class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d={value.icon}></path>
                </svg>
              </div>
              <h3 class="mt-5 text-xl font-semibold text-white">{value.title}</h3>
              <p class="mt-3 text-sm leading-7 text-slate-400">{value.description}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section id="servicios" class="py-18 md:py-24">
      <div class="section-shell">
        <div class="grid gap-8 lg:grid-cols-[minmax(0,0.82fr)_minmax(0,1fr)] lg:items-end">
          <div class="reveal" data-reveal>
            <div class="eyebrow">Servicios</div>
            <h2 class="section-title mt-5">Capacidades para diseñar, lanzar y evolucionar productos digitales con intención.</h2>
          </div>
          <p class="section-copy reveal stagger-1 max-w-2xl lg:justify-self-end" data-reveal>
            Trabajamos desde necesidades concretas de negocio: captar más demanda, operar mejor, centralizar datos, automatizar tareas o construir un producto digital con una base técnica confiable.
          </p>
        </div>

        <div class="mt-12 grid gap-4 md:grid-cols-2 xl:grid-cols-3">
          {services.map((service, index) => (
            <div class={`${index === 1 ? "stagger-1" : ""} ${index === 2 ? "stagger-2" : ""} ${index === 3 ? "stagger-1" : ""} ${index === 4 ? "stagger-2" : ""} ${index === 5 ? "stagger-3" : ""} reveal`} data-reveal>
              <ServiceCard {...service} />
            </div>
          ))}
        </div>
      </div>
    </section>

    <OfferSection />
    <ProcessSection />

    <section class="py-18 md:py-24">
      <div class="section-shell">
        <div class="grid gap-8 lg:grid-cols-[minmax(0,0.92fr)_minmax(280px,0.78fr)] lg:items-center">
          <div class="reveal" data-reveal>
            <div class="eyebrow">Por qué Malabs</div>
            <h2 class="section-title mt-5">Malabs combina ingeniería, datos, automatización e IA para resolver problemas de negocio con criterio práctico.</h2>
            <p class="section-copy mt-5 max-w-3xl">
              No se trata de sumar herramientas por tendencia. Se trata de entender qué necesita tu operación, qué debe construirse primero y cómo conectar diseño, tecnología y ejecución para generar un resultado útil.
            </p>
            <p class="section-copy mt-4 max-w-3xl">
              Trabajamos con una mentalidad de producto: claridad en el alcance, decisiones técnicas razonables y foco en entregar valor visible desde versiones tempranas sin comprometer la base del proyecto.
            </p>
          </div>

          <div class="grid gap-4 reveal stagger-1" data-reveal>
            <div class="section-card rounded-[1.75rem] p-6">
              <p class="text-sm font-semibold uppercase tracking-[0.22em] text-cyan-200">Enfoque</p>
              <p class="mt-4 text-lg font-semibold text-white">Soluciones que aterrizan estrategia en ejecución.</p>
            </div>
            <div class="section-card rounded-[1.75rem] p-6">
              <p class="text-sm font-semibold uppercase tracking-[0.22em] text-violet-200">Capacidad</p>
              <p class="mt-4 text-lg font-semibold text-white">Producto digital, integración, analítica y automatización en una sola conversación.</p>
            </div>
            <div class="section-card rounded-[1.75rem] p-6">
              <p class="text-sm font-semibold uppercase tracking-[0.22em] text-cyan-200">Resultado</p>
              <p class="mt-4 text-lg font-semibold text-white">Implementaciones más claras, más rápidas y mejor alineadas con objetivos reales.</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <ContactSection />
  </main>
  <Footer />
</BaseLayout>
