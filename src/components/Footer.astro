---
const footerLinks = [
  { href: "#inicio", label: "Inicio" },
  { href: "#servicios", label: "Servicios" },
  { href: "#proyectos", label: "Proyectos" },
  { href: "#oferta", label: "Oferta" },
  { href: "#contacto", label: "Contacto" },
  { href: "/contacto", label: "Contacto directo" }
];

const isHome = Astro.url.pathname === "/";
const withHomePath = (href: string) =>
  href.startsWith("#") && !isHome ? `/${href}` : href;
---

<footer class="pb-8 pt-6">
  <div class="section-shell">
    <div class="panel-dark rounded-[2rem] px-6 py-8 text-white md:px-8">
      <div class="grid gap-8 lg:grid-cols-[minmax(0,1fr)_auto] lg:items-end">
        <div class="max-w-xl">
          <img src="/brand/malabs-logo-horizontal.svg" alt="MAlabs" class="h-10 w-auto" />
          <p class="mt-5 text-sm font-semibold uppercase tracking-[0.18em] text-slate-200">MAlabs</p>
          <p class="mt-2 text-sm text-slate-300">MAlabs Group S.A.S.</p>
          <p class="mt-4 text-sm leading-7 text-slate-300">
            Software, automatización, datos e inteligencia artificial para convertir ideas en impacto real.
          </p>
        </div>

        <nav class="flex flex-wrap gap-4 text-sm text-slate-300 lg:justify-end" aria-label="Enlaces del pie de página">
          {footerLinks.map((item) => (
            <a href={withHomePath(item.href)} class="hover:text-white">
              {item.label}
            </a>
          ))}
        </nav>
      </div>

      <div class="mt-8 border-t border-white/10 pt-5 text-sm text-slate-400">
        &copy; 2026 MAlabs Group S.A.S. Todos los derechos reservados.
      </div>
    </div>
  </div>
</footer>
