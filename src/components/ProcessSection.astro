---
const steps = [
  {
    step: "01",
    title: "Descubrimiento",
    description: "Alineamos contexto, objetivos, alcance y prioridades para tomar decisiones con claridad desde el inicio."
  },
  {
    step: "02",
    title: "Diseño",
    description: "Definimos experiencia, estructura y solución técnica con foco en usabilidad, negocio y velocidad de ejecución."
  },
  {
    step: "03",
    title: "Desarrollo",
    description: "Construimos con una base limpia, integraciones útiles y una implementación lista para operar sin fricción."
  },
  {
    step: "04",
    title: "Lanzamiento",
    description: "Publicamos, conectamos lo necesario y dejamos el proyecto listo para iterar, medir y escalar."
  }
];
---

<section id="proceso" class="py-18 md:py-24">
  <div class="section-shell">
    <div class="mx-auto max-w-3xl text-center reveal" data-reveal>
      <div class="eyebrow">Proceso</div>
      <h2 class="section-title mt-5">Un proceso simple para avanzar con foco y sin ruido.</h2>
      <p class="section-copy mt-5">
        Combinamos descubrimiento, diseño y ejecución técnica en un flujo claro para transformar una necesidad de negocio en una solución lista para operar.
      </p>
    </div>

    <div class="relative mt-12 grid gap-4 lg:grid-cols-4">
      <div class="absolute left-12 right-12 top-10 hidden h-px bg-gradient-to-r from-cyan-400/40 via-violet-400/40 to-cyan-400/40 lg:block"></div>
      {steps.map((item, index) => (
        <article class={`section-card card-hover reveal rounded-[1.75rem] p-6 ${index === 1 ? "stagger-1" : ""} ${index === 2 ? "stagger-2" : ""} ${index === 3 ? "stagger-3" : ""}`} data-reveal>
          <div class="relative flex h-12 w-12 items-center justify-center rounded-2xl border border-slate-700/70 bg-slate-950/70 text-sm font-semibold text-white">
            {item.step}
          </div>
          <h3 class="mt-5 text-xl font-semibold text-white">{item.title}</h3>
          <p class="mt-3 text-sm leading-7 text-slate-400">{item.description}</p>
        </article>
      ))}
    </div>
  </div>
</section>
