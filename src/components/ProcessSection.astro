---
const steps = [
  {
    step: "01",
    title: "Descubrimiento",
    description: "Aterrizamos contexto, objetivos y prioridades para decidir qué construir primero y por qué."
  },
  {
    step: "02",
    title: "Diseño",
    description: "Definimos experiencia, estructura y enfoque visual para comunicar valor con claridad."
  },
  {
    step: "03",
    title: "Desarrollo",
    description: "Construimos con una base sólida, integraciones útiles y decisiones técnicas pensadas para escalar."
  },
  {
    step: "04",
    title: "Lanzamiento",
    description: "Publicamos, conectamos lo necesario y dejamos la solución lista para operar, medir e iterar."
  }
];
---

<section id="proceso" class="pt-6 pb-18 md:pt-8 md:pb-24">
  <div class="section-shell">
    <div class="mx-auto max-w-3xl text-center reveal" data-reveal>
      <div class="eyebrow">Proceso</div>
      <h2 class="section-title mt-5">Un proceso simple para avanzar con foco y sin ruido.</h2>
      <p class="section-copy mt-5">
        Combinamos descubrimiento, diseño y ejecución técnica en un flujo claro para transformar una necesidad de negocio en una solución lista para usarse.
      </p>
    </div>

    <div class="relative mt-12 grid gap-4 lg:grid-cols-4">
      <div class="absolute left-16 right-16 top-10 hidden h-px bg-gradient-to-r from-sky-500/28 via-violet-500/28 to-cyan-500/28 lg:block"></div>
      {steps.map((item, index) => (
        <article class={`section-card card-hover reveal rounded-[1.75rem] p-6 ${index === 1 ? "stagger-1" : ""} ${index === 2 ? "stagger-2" : ""} ${index === 3 ? "stagger-3" : ""}`} data-reveal>
          <div class="relative flex h-12 w-12 items-center justify-center rounded-2xl border border-slate-200 bg-white text-sm font-semibold text-slate-950 shadow-[0_14px_34px_rgba(16,43,87,0.08)]">
            {item.step}
          </div>
          <h3 class="mt-5 text-xl font-semibold text-slate-950">{item.title}</h3>
          <p class="mt-3 text-sm leading-7 text-slate-600">{item.description}</p>
        </article>
      ))}
    </div>
  </div>
</section>
