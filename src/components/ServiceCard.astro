---
interface Props {
  title: string;
  description: string;
  icon: string;
}

const { title, description, icon } = Astro.props;
---

<article class="section-card card-hover h-full rounded-[1.75rem] p-6">
  <div class="flex h-12 w-12 items-center justify-center rounded-2xl border border-cyan-400/20 bg-cyan-400/10 text-cyan-200">
    <svg viewBox="0 0 24 24" class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <path d={icon}></path>
    </svg>
  </div>
  <h3 class="mt-5 text-xl font-semibold text-white">{title}</h3>
  <p class="mt-3 text-sm leading-7 text-slate-400">{description}</p>
</article>
