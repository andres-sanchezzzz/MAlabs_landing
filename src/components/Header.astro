---
const navItems = [
  { href: "#inicio", label: "Inicio" },
  { href: "#servicios", label: "Servicios" },
  { href: "#proceso", label: "Proceso" },
  { href: "#oferta", label: "Oferta" },
  { href: "#contacto", label: "Contacto" }
];
---

<header class="sticky top-0 z-50">
  <div class="section-shell pt-5">
    <div class="section-card flex items-center justify-between rounded-full px-4 py-3 md:px-6">
      <a href="#inicio" class="flex items-center gap-3" aria-label="Malabs Group, ir al inicio">
        <img src="/brand/malabs-logo-stacked.svg" alt="Malabs Group" class="h-9 w-auto" />
      </a>

      <nav class="hidden items-center gap-8 md:flex" aria-label="Navegación principal">
        {navItems.map((item) => (
          <a href={item.href} class="nav-link">
            {item.label}
          </a>
        ))}
      </nav>

      <div class="hidden md:block">
        <a href="#contacto" class="button-primary">
          Agenda una llamada
        </a>
      </div>

      <button
        type="button"
        class="inline-flex h-11 w-11 items-center justify-center rounded-full border border-slate-700/70 bg-slate-950/70 text-slate-100 md:hidden"
        aria-label="Abrir menú"
        aria-expanded="false"
        aria-controls="mobile-menu"
        data-menu-toggle
      >
        <span class="sr-only">Abrir menú</span>
        <span class="flex flex-col gap-1.5">
          <span class="block h-0.5 w-5 rounded-full bg-current"></span>
          <span class="block h-0.5 w-5 rounded-full bg-current"></span>
          <span class="block h-0.5 w-5 rounded-full bg-current"></span>
        </span>
      </button>
    </div>

    <div
      id="mobile-menu"
      class="section-card mt-3 hidden rounded-3xl p-4 md:hidden"
      data-mobile-menu
    >
      <nav class="flex flex-col gap-2" aria-label="Navegación móvil">
        {navItems.map((item) => (
          <a href={item.href} class="rounded-2xl px-4 py-3 text-sm font-medium text-slate-200 hover:bg-slate-800/70">
            {item.label}
          </a>
        ))}
        <a href="#contacto" class="button-primary mt-2 w-full">
          Agenda una llamada
        </a>
      </nav>
    </div>
  </div>
</header>

<script is:inline>
  const toggleButton = document.querySelector("[data-menu-toggle]");
  const mobileMenu = document.querySelector("[data-mobile-menu]");

  if (toggleButton && mobileMenu) {
    const closeMenu = () => {
      mobileMenu.classList.add("hidden");
      toggleButton.setAttribute("aria-expanded", "false");
    };

    toggleButton.addEventListener("click", () => {
      const isExpanded = toggleButton.getAttribute("aria-expanded") === "true";
      mobileMenu.classList.toggle("hidden", isExpanded);
      toggleButton.setAttribute("aria-expanded", String(!isExpanded));
    });

    mobileMenu.querySelectorAll("a").forEach((link) => {
      link.addEventListener("click", closeMenu);
    });

    window.addEventListener("resize", () => {
      if (window.innerWidth >= 768) {
        closeMenu();
      }
    });
  }
</script>
